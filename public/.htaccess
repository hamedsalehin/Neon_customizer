<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Redirect www to non-www (dynamic for staging and production)
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^(.*)$ %{REQUEST_SCHEME}://%1/$1 [R=301,L]

    # 2. Redirect index.html to root / (uses REQUEST_URI to avoid internal directory index redirect loops)
    RewriteCond %{REQUEST_URI} ^/index\.html$ [NC]
    RewriteRule ^(index\.html)?$ %{REQUEST_SCHEME}://%{HTTP_HOST}/ [R=301,L]

    # 3. Serve extension-less URLs as .html files
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^([^\.]+)$ $1.html [NC,L]
</IfModule>
